generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  GYM_OWNER
  GYM_STAFF
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  password      String
  role          UserRole @default(USER)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}